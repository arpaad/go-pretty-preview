{
  "name": "go-pretty-preview",
  "displayName": "Go Pretty Preview",
  "description": "Read-only rendered preview for Go files with improved readability",
  "version": "0.1.0",
  "publisher": "luckyman42",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luckyman42/go-pretty-preview.git"
  },
  "bugs": {
    "url": "https://github.com/Luckyman42/go-pretty-preview/issues"
  },
  "homepage": "https://github.com/Luckyman42/go-pretty-preview#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goPreview.openPreview",
        "title": "Go Preview: Open Preview to Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "goPreview.togglePreview",
        "title": "Go Preview: Toggle Preview",
        "icon": "$(open-preview)"
      }
    ],
    "keybindings": [
      {
        "command": "goPreview.togglePreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == go && editorFocus"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "goPreview.openPreview",
          "when": "editorLangId == go",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Go Pretty Preview",
      "properties": {
        "goPreview.openByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the Go preview panel when a Go file is activated"
        },
        "goPreview.rules.inlineOneLineIf": {
          "type": "boolean",
          "default": true,
          "description": "Inline one-line if/else-if/else blocks onto a single line"
        },
        "goPreview.rules.fadePackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names whose qualifier (e.g. fmt.) is rendered dimmed in the preview. Example: [\"fmt\", \"sync\", \"context\"]"
        },
        "goPreview.rules.logVisibility": {
          "type": "string",
          "enum": [
            "normal",
            "fade",
            "hide",
            "highlight"
          ],
          "enumDescriptions": [
            "No change — log lines are shown as-is",
            "Dim log lines (grayscale + low opacity) so the eye skips over them",
            "Remove log lines from the preview entirely (enables inline-if for single-body blocks)",
            "Highlight log lines to see logging coverage at a glance"
          ],
          "default": "normal",
          "description": "How slog.* logging calls are rendered in the preview"
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "npm run typecheck && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "^0.20.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "highlight.js": "^11.9.0",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "shiki": "^4.1.0",
    "tree-sitter-go": "^0.25.0",
    "web-tree-sitter": "^0.26.9"
  }
}
