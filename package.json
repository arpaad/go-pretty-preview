{
  "name": "go-pretty-preview",
  "displayName": "Go Pretty Preview",
  "description": "Read-only rendered preview for Go files with improved readability",
  "version": "0.1.0",
  "publisher": "arpaad",
  "icon": "media/icon.png",
  "keywords": [
    "go",
    "golang",
    "preview",
    "readability",
    "code review"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arpaad/go-pretty-preview.git"
  },
  "bugs": {
    "url": "https://github.com/arpaad/go-pretty-preview/issues"
  },
  "homepage": "https://github.com/arpaad/go-pretty-preview#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goPreview.openPreview",
        "title": "Go Preview: Open Preview to Side",
        "icon": "$(open-preview)"
      },
      {
        "command": "goPreview.openPreviewOnly",
        "title": "Go Preview: Open as Preview Only",
        "icon": "$(preview)"
      },
      {
        "command": "goPreview.togglePreview",
        "title": "Go Preview: Toggle Preview",
        "icon": "$(open-preview)"
      }
    ],
    "keybindings": [
      {
        "command": "goPreview.togglePreview",
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "when": "editorLangId == go && editorFocus"
      }
    ],
    "customEditors": [
      {
        "viewType": "goPreview.previewOnly",
        "displayName": "Go Pretty Preview",
        "selector": [
          {
            "filenamePattern": "*.go"
          }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "goPreview.openPreview",
          "when": "editorLangId == go",
          "group": "navigation"
        },
        {
          "command": "goPreview.openPreviewOnly",
          "when": "editorLangId == go",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Go Pretty Preview",
      "properties": {
        "goPreview.openByDefault": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the Go preview panel when a Go file is activated"
        },
        "goPreview.rules.inlineOneLineIf": {
          "type": "boolean",
          "default": true,
          "description": "Inline one-line if/else-if/else blocks onto a single line"
        },
        "goPreview.rules.fadePackages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Package names whose qualifier (e.g. fmt.) is rendered dimmed in the preview. Example: [\"fmt\", \"sync\", \"context\"]"
        },
        "goPreview.rules.previewRules": {
          "type": "object",
          "description": "Regexp-based display rules, applied in priority order: protect > highlight > hide > fade. Each property is a list of JavaScript regexp strings matched against the full text of each output line.",
          "properties": {
            "protect": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Lines matching any pattern are immune to all other rules."
            },
            "highlight": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Lines matching are highlighted. With capture groups, only the matched groups are highlighted."
            },
            "hide": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Lines matching are removed from the preview entirely."
            },
            "fade": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Lines matching are dimmed. With capture groups, only the matched groups are hidden (opacity 0)."
            }
          },
          "additionalProperties": false,
          "default": {}
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "npm run typecheck && node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.3.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "tree-sitter-go": "0.25.0",
    "web-tree-sitter": "0.26.9"
  }
}
