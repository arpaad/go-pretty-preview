{
  "name": "go-pretty-preview",
  "displayName": "Go Pretty Preview",
  "description": "Read-only rendered preview for Go files with improved readability",
  "version": "0.1.0",
  "publisher": "luckyman42",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Luckyman42/vscode-go-preview.git"
  },
  "bugs": {
    "url": "https://github.com/Luckyman42/vscode-go-preview/issues"
  },
  "homepage": "https://github.com/Luckyman42/vscode-go-preview#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:go"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "goPreview.openPreview",
        "title": "Go Preview: Open Preview to Side",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "goPreview.openPreview",
          "when": "editorLangId == go",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Go Pretty Preview",
      "properties": {
        "goPreview.rules.singleStatementIf": {
          "type": "boolean",
          "default": true,
          "description": "Collapse single-statement if/else-if/else blocks (return/break/continue) onto one line"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "highlight.js": "^11.9.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "shiki": "^4.1.0"
  }
}
